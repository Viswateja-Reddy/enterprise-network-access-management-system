        <script><![CDATA[(function executeRule(current, previous /*null when async*/) {

    // Execute only if Approval State has changed
    if (current.approval_state != previous.approval_state) {

        // Allow only these transitions
        var valid =
            (previous.approval_state == 'Requested' &&
                (current.approval_state == 'Approved' ||
                 current.approval_state == 'Rejected'));

        if (!valid) {

            gs.addErrorMessage(
                'Approval State cannot be changed manually. Please use the appropriate UI Action.'
            );

            current.approval_state = previous.approval_state;

            current.setAbortAction(true);

        }

    }

})(current, previous);]]></script>
